{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/ping.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "api/ping.ts"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/",
      "dest": "api/index.ts"
    }
  ]
}
